<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.media.*?>

<BorderPane xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.filesystemclientfx.DashboardController"
            styleClass="root-dark">

    <left>
        <VBox styleClass="sidebar" spacing="0" prefWidth="200">
            <VBox styleClass="sidebar-brand" alignment="CENTER">
                <Label text="⬡ FileVault" styleClass="brand-title"/>
            </VBox>
            <VBox styleClass="user-info" alignment="CENTER" spacing="4">
                <Label text="👤" styleClass="user-avatar"/>
                <Label fx:id="welcomeLabel" text="Welcome!" styleClass="user-name"/>
            </VBox>
            <VBox styleClass="nav-section" spacing="4">
                <Label text="NAVIGATION" styleClass="nav-section-label"/>
                <Button text="🏠  My Files" onAction="#handleNavFiles"
                        styleClass="nav-btn, nav-btn-active" maxWidth="Infinity"
                        fx:id="navFilesBtn"/>
                <Button text="🗑  Recycle Bin" onAction="#handleNavRecycleBin"
                        styleClass="nav-btn" maxWidth="Infinity" fx:id="navRecycleBtn"/>
                <Button text="📤 Shared with Me" onAction="#handleNavShared"
                        styleClass="nav-btn" maxWidth="Infinity" fx:id="navSharedBtn"/>
                <Button text="👥  Groups" onAction="#handleNavGroups"
                        styleClass="nav-btn" maxWidth="Infinity" fx:id="navGroupsBtn"/>
                <Button text="👑 Admin Panel" onAction="#handleNavAdmin"
                        styleClass="nav-btn" maxWidth="Infinity"
                        fx:id="navAdminBtn" visible="false" managed="false"/>
            </VBox>
            <Pane VBox.vgrow="ALWAYS"/>
            <VBox styleClass="sidebar-bottom" spacing="8">
                <Button fx:id="themeToggleBtn" text="☀ Light Mode"
                        onAction="#handleThemeToggle" styleClass="theme-btn" maxWidth="Infinity"/>
                <Button text="⇥  Logout" onAction="#handleLogout"
                        styleClass="logout-btn" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox styleClass="main-content" spacing="0">
            <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="15">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label fx:id="pathLabel" text="/ Home" styleClass="path-label"/>
                    <Label fx:id="statusLabel" text="" styleClass="status-label"/>
                </VBox>
                <Button text="⬆ Up" onAction="#handleGoUp"
                        styleClass="action-btn-small" fx:id="goUpBtn"/>
                <Button text="↻ Refresh" onAction="#handleRefresh"
                        styleClass="action-btn-small" fx:id="refreshBtn"/>
            </HBox>

            <HBox fx:id="tabBar" spacing="0" alignment="CENTER_LEFT"
                  style="-fx-background-color: #0a0e1a;
                         -fx-border-color: transparent transparent rgba(0,212,255,0.15) transparent;
                         -fx-border-width: 0 0 1 0; -fx-padding: 5 10 0 10;">
                <HBox fx:id="tabButtonsBox" spacing="3" alignment="CENTER_LEFT"/>
                <Button text="＋" onAction="#handleNewTab"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: rgba(0,212,255,0.6); -fx-font-size: 16px;
                               -fx-cursor: hand; -fx-border-width: 0; -fx-padding: 2 10 2 10;"/>
            </HBox>

            <HBox styleClass="search-bar" spacing="10" alignment="CENTER_LEFT" fx:id="searchBar">
                <TextField fx:id="searchField"
                           promptText="🔍  Search files, folders, and groups..."
                           styleClass="search-input" HBox.hgrow="ALWAYS"
                           onKeyReleased="#handleSearch"/>
            </HBox>

            <HBox styleClass="action-bar" spacing="8" alignment="CENTER_LEFT" fx:id="actionBar">
                <Button text="📁 New Folder" onAction="#handleCreateFolder" styleClass="action-btn"/>
                <Button fx:id="createGroupBtn" text="👥 Create Group" onAction="#handleCreateGroup"
                        styleClass="action-btn-primary" visible="false" managed="false"/>
                <Button fx:id="addGroupMemberBtn" text="➕ Add Member" onAction="#handleAddGroupMember"
                        styleClass="action-btn" visible="false" managed="false"/>
                <Button text="⬆ Upload" onAction="#handleUpload" styleClass="action-btn-primary"/>
                <Button text="⬇ Download" onAction="#handleDownload" styleClass="action-btn"/>
                <Button text="📤 Share" onAction="#handleShare" styleClass="action-btn"/>
                <Button text="✏ Rename" onAction="#handleRename" styleClass="action-btn"/>
                <Button text="➡ Move" onAction="#handleMoveFile" styleClass="action-btn"/>
                <Button fx:id="sortBtn" text="↕ Sort" onAction="#handleSort" styleClass="action-btn"/>
                <Button text="🗑 Delete" onAction="#handleDelete" styleClass="action-btn-danger"/>
            </HBox>

            <HBox fx:id="bookmarksBar" spacing="6" alignment="CENTER_LEFT"
                  style="-fx-padding: 6 16 6 16;
                         -fx-background-color: rgba(0,212,255,0.03);
                         -fx-border-color: transparent transparent rgba(0,212,255,0.12) transparent;
                         -fx-border-width: 0 0 1 0;">
                <Label text="⭐" style="-fx-text-fill: rgba(0,212,255,0.5); -fx-font-size: 11px;"/>
                <ScrollPane fx:id="bookmarksScroll" hbarPolicy="NEVER" vbarPolicy="NEVER"
                            fitToHeight="true" HBox.hgrow="ALWAYS"
                            style="-fx-background-color: transparent; -fx-background: transparent;
                                   -fx-border-width: 0; -fx-padding: 0;">
                    <HBox fx:id="bookmarkButtonsBox" spacing="5" alignment="CENTER_LEFT"
                          style="-fx-padding: 0;"/>
                </ScrollPane>
                <Button text="+ Bookmark" onAction="#handleAddBookmark"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: rgba(0,212,255,0.5); -fx-font-size: 10px;
                               -fx-font-family: 'Courier New'; -fx-cursor: hand;
                               -fx-border-color: rgba(0,212,255,0.2); -fx-border-width: 1;
                               -fx-border-radius: 5; -fx-background-radius: 5;
                               -fx-padding: 3 8 3 8;"/>
            </HBox>

            <VBox styleClass="progress-section" spacing="4">
                <ProgressBar fx:id="uploadProgressBar" prefWidth="99999"
                             progress="0" visible="false" managed="false" styleClass="upload-progress"/>
                <Label fx:id="progressLabel" text="" styleClass="progress-label" visible="false" managed="false"/>
            </VBox>

            <HBox fx:id="fileView" spacing="0" VBox.vgrow="ALWAYS">
                <VBox fx:id="tableContainer" HBox.hgrow="ALWAYS" spacing="0" VBox.vgrow="ALWAYS"/>

                <VBox styleClass="preview-panel" spacing="12"
                      alignment="TOP_CENTER" prefWidth="240">
                    <Label text="PREVIEW" styleClass="preview-title"/>
                    <ImageView fx:id="imagePreview" fitWidth="200" fitHeight="200"
                               preserveRatio="true" visible="false"/>
                    <Label fx:id="previewLabel" text="Select a file to preview"
                           styleClass="preview-hint" wrapText="true"/>
                </VBox>
            </HBox>

            <VBox fx:id="videoView" VBox.vgrow="ALWAYS" visible="false" managed="false"
                  style="-fx-background-color: #000000;">
                <HBox alignment="CENTER_LEFT" spacing="12"
                      style="-fx-padding: 10 16 10 16; -fx-background-color: #0a0e1a;
                             -fx-border-color: transparent transparent rgba(0,212,255,0.2) transparent;
                             -fx-border-width: 0 0 1 0;">
                    <Label text="🎬" style="-fx-font-size: 16px;"/>
                    <Label fx:id="videoTitleLabel" text=""
                           style="-fx-text-fill: #ffffff; -fx-font-size: 13px;
                                  -fx-font-weight: bold; -fx-font-family: 'Courier New';"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button text="◀ Back to Files" onAction="#handleBackFromVideo"
                            style="-fx-background-color: rgba(0,212,255,0.08);
                                   -fx-text-fill: #00d4ff; -fx-font-size: 11px;
                                   -fx-font-family: 'Courier New'; -fx-background-radius: 7;
                                   -fx-padding: 7 14 7 14; -fx-cursor: hand;
                                   -fx-border-color: rgba(0,212,255,0.3);
                                   -fx-border-width: 1; -fx-border-radius: 7;"/>
                </HBox>
                <StackPane VBox.vgrow="ALWAYS" maxHeight="380"
                           style="-fx-background-color: #000000;">
                    <MediaView fx:id="mediaView" preserveRatio="true"/>
                </StackPane>
                <VBox style="-fx-padding: 10 16 4 16; -fx-background-color: #0a0e1a;">
                    <Slider fx:id="seekSlider" min="0" value="0" style="-fx-accent: #00d4ff;"/>
                    <HBox>
                        <Label fx:id="currentTimeLabel" text="00:00"
                               style="-fx-text-fill: rgba(0,212,255,0.7);
                                      -fx-font-size: 11px; -fx-font-family: 'Courier New';"/>
                        <Pane HBox.hgrow="ALWAYS"/>
                        <Label fx:id="totalTimeLabel" text="00:00"
                               style="-fx-text-fill: rgba(0,212,255,0.7);
                                      -fx-font-size: 11px; -fx-font-family: 'Courier New';"/>
                    </HBox>
                </VBox>
                <HBox alignment="CENTER" spacing="12"
                      style="-fx-padding: 10 16 14 16; -fx-background-color: #0a0e1a;
                             -fx-border-color: rgba(0,212,255,0.15) transparent transparent transparent;
                             -fx-border-width: 1 0 0 0;">
                    <Button text="⏮ -10s" onAction="#handleVideoRewind"
                            style="-fx-background-color: rgba(0,212,255,0.08);
                                   -fx-text-fill: #00d4ff; -fx-font-size: 12px;
                                   -fx-font-family: 'Courier New'; -fx-background-radius: 8;
                                   -fx-padding: 8 14 8 14; -fx-cursor: hand;
                                   -fx-border-color: rgba(0,212,255,0.3);
                                   -fx-border-width: 1; -fx-border-radius: 8;"/>
                    <Button fx:id="playPauseBtn" text="▶" onAction="#handleVideoPlayPause"
                            style="-fx-background-color: #00d4ff; -fx-text-fill: #020408;
                                   -fx-font-size: 16px; -fx-font-weight: bold;
                                   -fx-background-radius: 50; -fx-padding: 8 18 8 18;
                                   -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian, #00d4ff, 15, 0.6, 0, 0);"/>
                    <Button text="+10s ⏭" onAction="#handleVideoForward"
                            style="-fx-background-color: rgba(0,212,255,0.08);
                                   -fx-text-fill: #00d4ff; -fx-font-size: 12px;
                                   -fx-font-family: 'Courier New'; -fx-background-radius: 8;
                                   -fx-padding: 8 14 8 14; -fx-cursor: hand;
                                   -fx-border-color: rgba(0,212,255,0.3);
                                   -fx-border-width: 1; -fx-border-radius: 8;"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button fx:id="muteBtn" text="🔊" onAction="#handleVideoMute"
                            style="-fx-background-color: transparent; -fx-text-fill: #00d4ff;
                                   -fx-font-size: 16px; -fx-cursor: hand; -fx-border-width: 0;"/>
                    <Slider fx:id="volumeSlider" min="0" max="100" value="80"
                            prefWidth="100" style="-fx-accent: #00d4ff;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
