<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<StackPane xmlns="http://javafx.com/javafx/8"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.filesystemclientfx.RegisterController"
           styleClass="root-pane">

    <VBox styleClass="login-container" alignment="CENTER" spacing="0">

        <VBox styleClass="login-header" alignment="CENTER" spacing="8">
            <Label text="⬡" styleClass="logo-icon"/>
            <Label text="FileVault" styleClass="app-title"/>
            <Label text="Create your account" styleClass="app-subtitle"/>
        </VBox>

        <VBox styleClass="login-card" spacing="18">
            <Label text="Register" styleClass="card-title"/>
            <Label text="Fill in your details below" styleClass="card-subtitle"/>

            <VBox spacing="6">
                <Label text="USERNAME" styleClass="field-label"/>
                <TextField fx:id="usernameField"
                           promptText="Choose a username"
                           styleClass="input-field"/>
            </VBox>

            <VBox spacing="6">
                <Label text="PASSWORD" styleClass="field-label"/>
                <PasswordField fx:id="passwordField"
                               promptText="Choose a password"
                               styleClass="input-field"/>
            </VBox>

            <VBox spacing="6">
                <Label text="CONFIRM PASSWORD" styleClass="field-label"/>
                <PasswordField fx:id="confirmPasswordField"
                               promptText="Confirm your password"
                               styleClass="input-field"/>
            </VBox>

            <Button text="Create Account"
                    onAction="#handleRegister"
                    styleClass="login-btn"
                    maxWidth="Infinity"/>

            <Label fx:id="messageLabel" styleClass="message-label"
                   wrapText="true"/>

            <HBox alignment="CENTER" spacing="5">
                <Label text="Already have an account?" styleClass="register-text"/>
                <Button text="Sign In"
                        onAction="#handleBackToLogin"
                        styleClass="link-btn"/>
            </HBox>
        </VBox>

    </VBox>

</StackPane>